# =====================================================================
# NICECHAT_BASE — 환경변수 예시
# 실제 .env 는 절대 git 에 커밋하지 말 것 (.gitignore 에 이미 제외됨)
# 안 쓰는 프로바이더 키는 비워두면 된다.
# =====================================================================

# ── 앱 ───────────────────────────────────────────────
ENV=local
DEBUG=true
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["*"]

# ── 로깅 ─────────────────────────────────────────────
# LOG_LEVEL: DEBUG/INFO/WARNING/ERROR
# LOG_FILE: 로그 파일 경로(회전 10MB×5). 비우면 파일 기록 끔.
# LOG_JSON_CONSOLE: true=콘솔도 JSON(운영), false=컬러 사람용(개발)
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_JSON_CONSOLE=false

# ── 보안 ─────────────────────────────────────────────
SECRET_KEY=change-me-please-use-a-strong-random-value
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── PostgreSQL ───────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/nicechat

# ── Redis (대화 이력 + 응답 캐시, Phase 6) ───────────
# Redis 미기동이어도 채팅은 동작(이력/캐시만 자동 스킵). 켜려면 docker compose up -d redis.
REDIS_URL=redis://localhost:6379/0
MEMORY_ENABLED=true
HISTORY_MAX_MESSAGES=20
CACHE_ENABLED=true
CACHE_TTL_SECONDS=3600

# ── Vector DB (Qdrant) ───────────────────────────────
# 모드: http://... (도커/원격 서버) | ./.qdrant_local (로컬 임베디드, 도커 불필요) | :memory: (임시)
VECTOR_DB_URL=http://localhost:6333
VECTOR_DB_API_KEY=
VECTOR_COLLECTION=documents

# ── Graph DB (Neo4j) ─────────────────────────────────
GRAPH_DB_URI=bolt://localhost:7687
GRAPH_DB_USER=neo4j
GRAPH_DB_PASSWORD=password

# ── LLM / 임베딩 / 리랭커 프로바이더 키 ──────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
COHERE_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
VOYAGE_API_KEY=
HUGGINGFACE_API_KEY=
UPSTAGE_API_KEY=

# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-06-01

# ── 기본 모델 ("provider:model" 형식) ────────────────
# chat=Anthropic(키 필요), embedding=로컬 bge-m3(무료, 키 불필요).
# 다른 프로바이더로 바꾸려면 값만 교체(예: openai:gpt-4o-mini / openai:text-embedding-3-small).
DEFAULT_CHAT_MODEL=anthropic:claude-haiku-4-5-20251001
DEFAULT_EMBEDDING_MODEL=st:BAAI/bge-m3
DEFAULT_RERANK_MODEL=cohere:rerank-multilingual-v3.0
# 서버 시작 시 임베딩 모델 미리 로드(첫 질문 14초 대기 제거). MOCK_RETRIEVER 면 자동 스킵.
EMBEDDING_WARMUP=true

# ── Langfuse (LLM 트레이싱) ──────────────────────────
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
