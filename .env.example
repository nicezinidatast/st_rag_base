# =====================================================================
# NICECHAT_BASE — 환경변수 예시
# 실제 .env 는 절대 git 에 커밋하지 말 것 (.gitignore 에 이미 제외됨)
# 안 쓰는 프로바이더 키는 비워두면 된다.
# =====================================================================

# ── 앱 ───────────────────────────────────────────────
ENV=local
DEBUG=true
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["*"]

# ── 보안 ─────────────────────────────────────────────
SECRET_KEY=change-me-please-use-a-strong-random-value
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── PostgreSQL ───────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/nicechat

# ── Redis ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Vector DB (Qdrant) ───────────────────────────────
# 모드: http://... (도커/원격 서버) | ./.qdrant_local (로컬 임베디드, 도커 불필요) | :memory: (임시)
VECTOR_DB_URL=http://localhost:6333
VECTOR_DB_API_KEY=
VECTOR_COLLECTION=documents

# ── Graph DB (Neo4j) ─────────────────────────────────
GRAPH_DB_URI=bolt://localhost:7687
GRAPH_DB_USER=neo4j
GRAPH_DB_PASSWORD=password

# ── LLM / 임베딩 / 리랭커 프로바이더 키 ──────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
COHERE_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
VOYAGE_API_KEY=
HUGGINGFACE_API_KEY=
UPSTAGE_API_KEY=

# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-06-01

# ── 기본 모델 ("provider:model" 형식) ────────────────
# chat=Anthropic(키 필요), embedding=로컬 bge-m3(무료, 키 불필요).
# 다른 프로바이더로 바꾸려면 값만 교체(예: openai:gpt-4o-mini / openai:text-embedding-3-small).
DEFAULT_CHAT_MODEL=anthropic:claude-haiku-4-5-20251001
DEFAULT_EMBEDDING_MODEL=st:BAAI/bge-m3
DEFAULT_RERANK_MODEL=cohere:rerank-multilingual-v3.0

# ── Langfuse (LLM 트레이싱) ──────────────────────────
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
